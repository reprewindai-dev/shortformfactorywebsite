{
  "outputDirectory": ".",
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/concierge/:path*", "destination": "/api/index.js" },
    { "source": "/api/capture/email", "destination": "/api/index.js" },
    { "source": "/api/capture/unsubscribe", "destination": "/api/index.js" },
    { "source": "/api/funnel/cron", "destination": "/api/index.js" },
    { "source": "/api/leads/:path*", "destination": "/api/index.js" },
    { "source": "/api/paypal/:path*", "destination": "/api/index.js" },
    { "source": "/api/stripe/:path*", "destination": "/api/index.js" },
    { "source": "/api/create-order", "destination": "/api/index.js" },
    { "source": "/api/capture-order", "destination": "/api/index.js" },
    { "source": "/api/webhook", "destination": "/api/index.js" }
  ],
  "routes": [
    { "src": "/faq", "dest": "/faq/index.html" },
    { "src": "/faq/", "dest": "/faq/index.html" },
    { "src": "/trademark", "dest": "/trademark/index.html" },
    { "src": "/trademark/", "dest": "/trademark/index.html" },
    { "src": "/terms", "dest": "/terms/index.html" },
    { "src": "/terms/", "dest": "/terms/index.html" },
    { "src": "/privacy", "dest": "/privacy/index.html" },
    { "src": "/privacy/", "dest": "/privacy/index.html" }
  ]
}