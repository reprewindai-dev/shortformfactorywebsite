# PayPal API Configuration
# Copy this file to .env.local and fill in your credentials

# PayPal Mode: 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# PayPal Sandbox Credentials (from https://developer.paypal.com/dashboard/applications/sandbox)
PAYPAL_CLIENT_ID=your_sandbox_client_id_here
PAYPAL_CLIENT_SECRET=your_sandbox_client_secret_here

# PayPal Webhook ID (from PayPal Developer Dashboard > Webhooks)
# Required for webhook signature verification
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# ===========================================
# CONCIERGE AI CONFIGURATION
# ===========================================

# Hugging Face API Token (optional - system works without it)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here

# Email Service Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=concierge@shortformfactory.com

# Stripe Configuration
# Obtain keys from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
# Optional: if you later add webhook validation
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Override the default URLs if deploying to a different domain
# Include {CHECKOUT_SESSION_ID} so the thank-you page can look up session details
STRIPE_SUCCESS_URL=https://shortformfactory.com/thank-you?provider=stripe&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://shortformfactory.com/order?status=cancelled

# Admin Dashboard
ADMIN_PASSWORD=ShortFormAdmin2026!

# Analytics (optional)
GOOGLE_ANALYTICS_ID=G-PE956KT8DY

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
#
# 1. Go to https://developer.paypal.com/dashboard/
# 2. Create a Sandbox App (or use the default one)
# 3. Copy your Client ID and Secret
# 4. Create a Webhook with URL: https://your-domain.com/api/webhook
#    Subscribe to these events:
#    - CHECKOUT.ORDER.APPROVED
#    - CHECKOUT.ORDER.COMPLETED
#    - PAYMENT.CAPTURE.COMPLETED
#    - PAYMENT.CAPTURE.DENIED
#    - PAYMENT.CAPTURE.REFUNDED
# 5. Copy the Webhook ID
#
# 6. For AI Enhancement (Optional):
#    - Sign up at https://huggingface.co/
#    - Get your API token from settings
#    - Add HUGGINGFACE_API_KEY to your environment
#
# 7. For Email Notifications:
#    - Sign up at https://resend.com/
#    - Get your API key
#    - Add RESEND_API_KEY and RESEND_FROM_EMAIL
#
# For Vercel deployment:
# - Add these as Environment Variables in your Vercel project settings
# - Do NOT commit the actual .env.local file with real credentials
